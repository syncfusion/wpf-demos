<democommon:DemoControl
    x:Class="syncfusion.datagriddemos.wpf.ExcelStyleSelectionDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
    xmlns:local="clr-namespace:syncfusion.datagriddemos.wpf"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf" >

    <democommon:DemoControl.DataContext>
        <local:ProductInfoViewModel />
    </democommon:DemoControl.DataContext>

    <interactivity:Interaction.Behaviors>
        <local:ExcelStyleSelectionBehavior />
    </interactivity:Interaction.Behaviors>

    <democommon:DemoControl.Resources>
        <local:SelectedImageConverter x:Key="selectedImageConverter" />  
        <democommon:EnumDisplayNameConverter x:Key="EnumDisplayNameConverter" />
        
        <Style TargetType="syncfusion:SfRatingItem">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Width" Value="22" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="syncfusion:SfRating">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="syncfusion:SfRating">
                        <Grid RenderTransformOrigin="0.5, 0.5">
                            <Grid x:Name="PART_ToolTip" HorizontalAlignment="Left">
                                <Popup x:Name="PART_Popup" VerticalOffset="-65">
                                    <Border
                                        Height="37"
                                        Padding="10,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        BorderThickness="1">

                                        <ContentPresenter
                                            x:Name="PART_Border"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Content="{Binding PreviewValue, RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                    </Border>
                                </Popup>
                            </Grid>
                            <Border
                                x:Name="PART_Host"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                                <ItemsPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </democommon:DemoControl.Resources>

    <democommon:DemoControl.Options>
        <StackPanel>
            <TextBlock
                x:Name="textBlock1"
                Margin="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold"
                Text="ColumnHeaderClickAction:" />
            <ComboBox
                x:Name="cmbColumnHeaderClickAction"
                Width="160"
                Margin="5"
                Height="24"
                HorizontalAlignment="Left"
                ItemsSource="{democommon:EnumValuesExtension Type=syncfusion:ColumnHeaderClickAction}"
                SelectedIndex="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <CheckBox
                x:Name="ckbAllowSorting"
                Margin="5"
                Height="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Content="AllowSorting"
                IsChecked="True" /> 
        </StackPanel>
    </democommon:DemoControl.Options>

    <Grid Margin="5">
        <syncfusion:SfDataGrid
                x:Name="syncgrid"
                Margin="5" 
                AutoGenerateColumns="False"
                ColumnSizer="Star"
                HeaderRowHeight="32"
                ItemsSource="{Binding ProductDetails}" 
                EnableExcelLikeSelection="True" 
                ShowSelectionFrame="True"
                SelectionMode="Extended" 
                SelectionUnit="Any"
                ShowRowHeader="True"
                ColumnHeaderClickAction="{Binding SelectedValue, ElementName=cmbColumnHeaderClickAction}" 
                AllowSorting="{Binding IsChecked, ElementName=ckbAllowSorting}">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:GridNumericColumn
                        HeaderText="Product ID"
                        MappingName="ProductID"
                        NumberDecimalDigits="0" />
                <syncfusion:GridTextColumn HeaderText="Product Model" MappingName="ProductModel" TextTrimming="CharacterEllipsis" />
                <syncfusion:GridTextColumn HeaderText="Brand" MappingName="Product" />
                <syncfusion:GridTextColumn HeaderText="Type" MappingName="ProductType" />
                <syncfusion:GridTextColumn DisplayBinding="{Binding Path=Price, StringFormat='{}{0:C}'}" TextAlignment="Right" />
                <syncfusion:GridTemplateColumn
                        HeaderText="User Rating"
                        MappingName="UserRating"
                        MinimumWidth="170">
                    <syncfusion:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <syncfusion:SfRating
                                    VerticalAlignment="Center"
                                    IsReadOnly="True"
                                    ItemsCount="5"
                                    ShowToolTip="False"
                                    Value="{Binding UserRating, Mode=TwoWay}" /> 
                        </DataTemplate>
                    </syncfusion:GridTemplateColumn.CellTemplate>
                </syncfusion:GridTemplateColumn>
                <syncfusion:GridTemplateColumn HeaderText="In Stock" MappingName="Availability">
                    <syncfusion:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image
                                    Width="14"
                                    Height="14"
                                    Source="{Binding Availability, Converter={StaticResource selectedImageConverter}, ConverterParameter=Availability}"
                                    Stretch="UniformToFill" />
                        </DataTemplate>
                    </syncfusion:GridTemplateColumn.CellTemplate>
                </syncfusion:GridTemplateColumn>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>
    </Grid>
</democommon:DemoControl>
