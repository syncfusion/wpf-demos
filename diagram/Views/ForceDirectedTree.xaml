<democommon:DemoControl  
             xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"  
            x:Class="syncfusion.diagramdemo.wpf.Views.ForceDirectedTree"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:local="clr-namespace:syncfusion.diagramdemo.wpf.Views"
            xmlns:viewmodel="clr-namespace:syncfusion.diagramdemo.wpf.ViewModel"
             mc:Ignorable="d" 
            d:DesignHeight="450" d:DesignWidth="800" OptionsSize="250">
    <democommon:DemoControl.DataContext>
        <viewmodel:ForceDirectedTreeViewModel/>
    </democommon:DemoControl.DataContext>
    <democommon:DemoControl.Resources>

        <DataTemplate x:Key="organizationalemployeeContentTemplate">
            <Grid Width="{Binding Width}" Height="{Binding Height}"
          VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Ellipse background -->
                <Ellipse Fill="{Binding Color}" Stroke="{Binding Color}"
                 StrokeThickness="3"/>
                <!-- Text -->
                <TextBlock Margin="5"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Foreground="#111111"
                   Text="{Binding Role}"
                   FontFamily="Segoe UI"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>
            </Grid>
        </DataTemplate>


        <Style TargetType="syncfusion:Node">
            <Setter Property="ContentTemplate" Value="{StaticResource organizationalemployeeContentTemplate}">

            </Setter>
            <Setter Property="UnitHeight" Value="130"/>
            <Setter Property="UnitWidth" Value="130"/>

        </Style>

        <!--Style for Connector-->
        <Style TargetType="syncfusion:Connector">
            <Setter Property="ConnectorGeometryStyle">
                <Setter.Value>
                    <Style TargetType="Path">
                        <Setter Property="Stroke" Value="Black"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="TargetDecoratorStyle">
                <Setter.Value>
                    <Style TargetType="Path">
                        <Setter Property="Fill" Value="Black"/>
                        <Setter Property="StrokeThickness" Value="1"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!--Style for UpDown - Center text horizontally and vertically-->
        <Style TargetType="syncfusion:UpDown">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,0,0"/>
        </Style>

    </democommon:DemoControl.Resources>
    <Grid>
        <!--Initialize Diagram-->
        <syncfusion:SfDiagram x:Name="sfdiagram"
                      Margin="5"
                      DefaultConnectorType="{Binding DefaultConnectorType}"  
                      Nodes="{Binding Nodes}"
                      Connectors="{Binding Connectors}"
                      DataSourceSettings="{Binding DataSourceSettings}"
                      LayoutManager="{Binding LayoutManager}"
                      Menu="{Binding Menu}"
                      Tool="{Binding Tool}"
                     Loaded="sfdiagram_Loaded">

        </syncfusion:SfDiagram>
    </Grid>
    <democommon:DemoControl.OptionsTitle>
            Properties
        </democommon:DemoControl.OptionsTitle>
    <democommon:DemoControl.Options>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" ></RowDefinition>
                <RowDefinition Height="35"></RowDefinition>
                <RowDefinition Height="35" ></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Margin="10,7,0,0" Grid.Row="0" Grid.Column="0" Padding="5" Text="Maximim Iteration" VerticalAlignment="Center"  Height="24"/>
            <syncfusion:UpDown MinValue="300" Margin="5,5,0,0" Grid.Row="0" Grid.Column="1" Step="50" Height="24" VerticalAlignment="Center"
                       Value="{Binding MaximumIteration, Mode=TwoWay}"/>

            <TextBlock Margin="10,7,0,0" Grid.Row="1" Grid.Column="0" Padding="5" Text="Repulsion Strength"  Height="24" VerticalAlignment="Center"/>
            <syncfusion:UpDown MinValue="25000" Margin="5,5,0,0" Grid.Row="1" Grid.Column="1" Step="250" MaxValue="35000" Height="24" VerticalAlignment="Center"
       Value="{Binding RepulsionStrength, Mode=TwoWay}" />

            <TextBlock Margin="10,7,0,0" Grid.Row="2" Grid.Column="0" Padding="5" Text="Attraction strength"  Height="24" VerticalAlignment="Center"/>
            <syncfusion:UpDown MinValue="0.1" MaxValue="1" Margin="5,5,0,0" Grid.Row="2" Grid.Column="1" Step="0.1" Height="24" VerticalAlignment="Center"
       Value="{Binding AttractionStrength, Mode=TwoWay}" />

        </Grid>
    </democommon:DemoControl.Options>
 
</democommon:DemoControl>
