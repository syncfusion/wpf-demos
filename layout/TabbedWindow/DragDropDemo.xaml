<sfchrome:SfChromelessWindow x:Class="syncfusion.layoutdemos.wpf.DragDropDemo"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:sfchrome="clr-namespace:Syncfusion.Windows.Controls;assembly=Syncfusion.SfChromelessWindow.Wpf"
     xmlns:syncfusion="http://schemas.syncfusion.com/wpf" 
     xmlns:local="clr-namespace:syncfusion.layoutdemos.wpf"
     xmlns:viewModel="clr-namespace:syncfusion.layoutdemos.wpf.ViewModel"
     WindowType="Tabbed"
     Width="800" Height="450"
     xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
     Loaded="SfChromelessWindow_Loaded">
    <sfchrome:SfChromelessWindow.DataContext>
        <viewModel:DragDropViewModel/>
    </sfchrome:SfChromelessWindow.DataContext>
    <Grid>
        <sfchrome:SfTabControl x:Name="MainTabControl"
                               ItemsSource="{Binding TopTabs}"
                               AllowDragDrop="True"
                               EnableNewTabButton="False">
            <sfchrome:SfTabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" />
                </DataTemplate>
            </sfchrome:SfTabControl.ItemTemplate>
            <sfchrome:SfTabControl.ContentTemplate>
                <DataTemplate>
                    <StackPanel Margin="12">
                        <TextBlock Text="{Binding Content}" FontWeight="Bold" FontSize="14" />
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,8,0,0" />
                        <TextBlock Text="Tip: Drag the tab out to create a new window; dock into another tabbed window." FontStyle="Italic" Margin="0,8,0,0" />
                    </StackPanel>
                </DataTemplate>
            </sfchrome:SfTabControl.ContentTemplate>
        </sfchrome:SfTabControl>
    </Grid>
</sfchrome:SfChromelessWindow>
