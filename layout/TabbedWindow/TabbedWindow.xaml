<sfchrome:SfChromelessWindow x:Class="syncfusion.layoutdemos.wpf.TabbedWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sfchrome="clr-namespace:Syncfusion.Windows.Controls;assembly=Syncfusion.SfChromelessWindow.Wpf"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf" 
    xmlns:local="clr-namespace:syncfusion.layoutdemos.wpf"
    WindowType="Tabbed"
    xmlns:viewModel="clr-namespace:syncfusion.layoutdemos.wpf.ViewModel" xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors">
    <sfchrome:SfChromelessWindow.DataContext>
        <viewModel:TabbedWindowViewModel />
    </sfchrome:SfChromelessWindow.DataContext>
    <Grid>
        <sfchrome:SfTabControl x:Name="sfTabControl" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <sfchrome:SfTabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" />
                </DataTemplate>
            </sfchrome:SfTabControl.ItemTemplate>
            <sfchrome:SfTabControl.ItemContainerStyle>
                <Style TargetType="{x:Type sfchrome:SfTabItem}">
                    <Setter Property="CloseButtonVisibility"
                    Value="{Binding CloseButtonVisibility, Mode=TwoWay}"/>
                </Style>
            </sfchrome:SfTabControl.ItemContainerStyle>
            <sfchrome:SfTabControl.ContentTemplate>
                <DataTemplate>
                    <local:UserView/>
                </DataTemplate>
            </sfchrome:SfTabControl.ContentTemplate>
            <interactivity:Interaction.Triggers>
                <interactivity:EventTrigger EventName="NewTabRequested">
                    <interactivity:InvokeCommandAction Command="{Binding AddTabCommand}" PassEventArgsToCommand="True" />
                </interactivity:EventTrigger>
            </interactivity:Interaction.Triggers>
        </sfchrome:SfTabControl>
    </Grid>
</sfchrome:SfChromelessWindow>
