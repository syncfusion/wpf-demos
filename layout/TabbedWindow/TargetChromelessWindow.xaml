<sfchrome:SfChromelessWindow  xmlns:sfchrome="http://schemas.syncfusion.com/wpf" 
        x:Class="syncfusion.layoutdemos.wpf.TargetChromelessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:syncfusion.layoutdemos.wpf.ViewModel"
        xmlns:local="clr-namespace:syncfusion.layoutdemos.wpf"
        mc:Ignorable="d" WindowType="Tabbed"
        Title="TargetChromelessWindow" Height="450" Width="800">
    <sfchrome:SfChromelessWindow.DataContext>
        <viewModel:DragDropViewModel/>
    </sfchrome:SfChromelessWindow.DataContext>
    <Grid>
        <sfchrome:SfTabControl x:Name="targetTabControl" AllowDragDrop="True" PreviewTabMerge="SfTabControl_PreviewMerge" EnableNewTabButton="False">
            <sfchrome:SfTabItem Header="Locked — Sector α">
                <StackPanel Margin="12">
                    <TextBlock Text="Tabs from this group cannot be dragged to the first tabbed window." FontWeight="Bold" />
                    <TextBlock Text="Reason: this control does not use the PreviewMerge event, so cross-window merging is not performed for these tabs." TextWrapping="Wrap" Margin="0,6,0,0" />
                    <TextBlock Text="This is the default behavior when drag-and-drop happens between tab controls with different data types." FontStyle="Italic" Margin="0,6,0,0" />
                </StackPanel>
            </sfchrome:SfTabItem>
            <sfchrome:SfTabItem Header="Group ‹NoMerge›">
                <StackPanel Margin="12">
                    <TextBlock Text="These tabs are intentionally isolated: they won't merge into the primary tabbed window." FontWeight="Bold" />
                    <TextBlock Text="Try dragging: you will see the merge won't occur because PreviewMerge isn't handled here." TextWrapping="Wrap" Margin="0,6,0,0" />
                    <TextBlock Text="Use this to compare behavior with the demo window where PreviewMerge is enabled." FontStyle="Italic" Margin="0,6,0,0" />
                </StackPanel>
            </sfchrome:SfTabItem>
            <sfchrome:SfTabItem Header="VoidBox#3">
                <StackPanel Margin="12">
                    <TextBlock Text="No-merge tab: cross-window docking disabled for this group." FontWeight="Bold" />
                    <TextBlock Text="Default control behavior: without PreviewMerge, the target control cannot accept items of a different data type." TextWrapping="Wrap" Margin="0,6,0,0" />
                    <TextBlock Text="Observe the difference between this window and the demo window." FontStyle="Italic" Margin="0,6,0,0" />
                </StackPanel>
            </sfchrome:SfTabItem>
        </sfchrome:SfTabControl>
    </Grid>
</sfchrome:SfChromelessWindow>
