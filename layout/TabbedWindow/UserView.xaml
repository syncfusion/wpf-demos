<UserControl x:Class="syncfusion.layoutdemos.wpf.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sfchrome="clr-namespace:Syncfusion.Windows.Controls;assembly=Syncfusion.SfChromelessWindow.Wpf"
             xmlns:local="clr-namespace:syncfusion.layoutdemos.wpf"
             mc:Ignorable="d" 
             xmlns:viewModel="clr-namespace:syncfusion.layoutdemos.wpf.ViewModel"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="InstructionsTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <DataTemplate x:Key="Tab1Instructions">
            <StackPanel>
                <TextBlock Style="{StaticResource InstructionsTextBlockStyle}">
            <Run Text="Use this tab to try basic tab drag and drop operations."/>
                </TextBlock >
                <Border Margin="0,12,0,0">
                    <StackPanel>
                        <Border HorizontalAlignment="Left"
                        Margin="0,0,0,8">
                            <TextBlock
                               FontWeight="Bold"
                               Text="Try dragging this tab"/>
                        </Border>
                        <TextBlock Style="{StaticResource InstructionsTextBlockStyle}">
                    <Run Text="• Enable "/>
                    <Run Text="Allow Drag Drop" FontStyle="Italic"/>
                    <Run Text=" to move tabs."/>
                    <LineBreak/>
                    <Run Text="• Drag a tab header left or right to reorder."/>
                    <LineBreak/>
                    <Run Text="• Open two windows and drag a tab between them."/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0"
                BorderThickness="1">
                    <TextBlock Style="{StaticResource InstructionsTextBlockStyle}">
                <Run Text="Tip: " FontWeight="Bold"/>
                <Run Text="Drag and drop works only when 'Allow Drag Drop' is enabled."/>
                    </TextBlock>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="Tab2Instructions">
            <TextBlock Style="{StaticResource InstructionsTextBlockStyle}">
                <Run Text="Welcome to Tab 2 — Advanced actions"/>
                <LineBreak/><LineBreak/>
                <Rectangle Height="1" Width="Auto"/>
                <LineBreak/>
                <Run Text="Try these:" FontWeight="Bold" FontSize="14"/>
                <LineBreak/><LineBreak/>
                <Run Text="• Set "/><Run Text="Window Type" FontStyle="Italic"/><Run Text=" to "/><Run Text="Tabbed" FontWeight="SemiBold"/><Run Text=" and open a second window."/>
                <LineBreak/>
                <Run Text="• Hide the "/><Run Text="New Tab" FontStyle="Italic"/><Run Text=" (+) button by unchecking "/><Run Text="Enable New Button" FontStyle="Italic"/><Run Text="."/>
                <LineBreak/>
                <Run Text="• Toggle Close/Pin visibility and observe header changes."/>
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="Tab3Instructions">
            <TextBlock Style="{StaticResource InstructionsTextBlockStyle}">
                <Run Text="Explore this tab:"/>
                <LineBreak/><LineBreak/>
                <Rectangle Height="1" Width="Auto"/>
                <LineBreak/>
                <Run Text="• Use the options on the right to adjust window/tab behaviors."/>
                <LineBreak/>
                <Run Text="• Switch window type, toggle title bar, and configure tab buttons."/>
            </TextBlock>
        </DataTemplate>

        <DataTemplate x:Key="DefaultInstructions">
            <TextBlock Text="{Binding Header}" />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <ContentPresenter Content="{Binding}">
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="ContentTemplate" Value="{StaticResource DefaultInstructions}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Header}" Value="Tab 1">
                                <Setter Property="ContentTemplate" Value="{StaticResource Tab1Instructions}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Header}" Value="Tab 2">
                                <Setter Property="ContentTemplate" Value="{StaticResource Tab2Instructions}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Header}" Value="Tab 3">
                                <Setter Property="ContentTemplate" Value="{StaticResource Tab3Instructions}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>
        </ScrollViewer>

        <Border Grid.Column="1" Margin="12,0,0,0" Padding="8"
                CornerRadius="4">
            <StackPanel>
                <StackPanel.DataContext>
                    <Binding Path="DataContext"
                             RelativeSource="{RelativeSource AncestorType={x:Type sfchrome:SfChromelessWindow}}"/>
                </StackPanel.DataContext>

                <TextBlock Text="Options" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>

                <CheckBox Content="Enable Title"
                    IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type sfchrome:SfChromelessWindow}},
                    Path=EnableTitle,
                    Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="WindowType" FontWeight="Bold" Margin="0,12,0,-2"/>
                <ComboBox Margin="0,8,0,0" Width="160"
                         ItemsSource="{Binding WindowTypeOptions}"
                         SelectedItem="{Binding RelativeSource={RelativeSource AncestorType={x:Type sfchrome:SfChromelessWindow}},
                       Path=WindowType, Mode=TwoWay}" />

                <CheckBox Content="Allow Drag Drop" Margin="0,12,0,0"
                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type sfchrome:SfTabControl}},
                          Path=AllowDragDrop, Mode=TwoWay}" />
                <CheckBox Content="Enable New Button" Margin="0,8,0,0"
                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type sfchrome:SfTabControl}},
                          Path=EnableNewTabButton, Mode=TwoWay}" />

                <TextBlock Text="Selected Item Properties" FontWeight="Bold" Margin="0,16,0,-2"/>

                <TextBlock Text="Close Button Visibility" FontWeight="Bold" Margin="0,16,0,-2"/>
                <ComboBox Width="160" Margin="0,8,0,0"
                          ItemsSource="{Binding VisibilityOptions}"
                          SelectedItem="{Binding
              RelativeSource={RelativeSource AncestorType={x:Type sfchrome:SfTabControl}},
              Path=SelectedItem.CloseButtonVisibility,
              Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
