<Window x:Class="syncfusion.notificationdemos.wpf.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:syncfusion.notificationdemos.wpf"
        mc:Ignorable="d"
        Title="ReceiptWindow" 
        Height="480" Width="720"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        FontSize="13">

    <Border Margin="14" Padding="12" CornerRadius="14" BorderThickness="1">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <DockPanel LastChildFill="True">
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    CornerRadius="14,14,0,0" BorderThickness="0 0 0 1">
                <Grid Margin="18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="OrderTitleText" FontSize="20" FontWeight="SemiBold" Text="Order #12345 — Preparing" />
                        <!-- ETA line extracted in code-behind and shown as subtle subtitle -->
                        <TextBlock x:Name="EtaText" Margin="0,4,0,0" Text="ETA: ~30 minutes"/>
                    </StackPanel>

                    <!-- Optional logo/badge on right -->
                    <Border Grid.Column="1"
                            CornerRadius="8" Padding="10,6" Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍽️" Margin="0,0,6,0"/>
                            <TextBlock Text="Receipt" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2.1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Left: customer & delivery details -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Delivery And Billing" FontWeight="SemiBold"/>
                        <Border BorderThickness="1" CornerRadius="10"
                            Margin="0,6,0,10" Padding="12">
                        <TextBlock x:Name="DetailsText" TextWrapping="Wrap" FontFamily="Consolas" Text="John Doe\n123 Main St, Coimbatore"/>
                    </Border>

                    <!-- Notes -->
                    <Border BorderThickness="1" CornerRadius="8"
                            Padding="12">
                        <TextBlock Text="This is a computer-generated invoice. Keep this for your records."
                                  />
                    </Border>
                </StackPanel>

                <!-- Right: totals card -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Order Summary" FontWeight="SemiBold"/>
                        <Border BorderThickness="1"
                            CornerRadius="10" Margin="0,8,0,12" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Item subtotal (computed in code-behind if you like, else left blank) -->
                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock Text="Subtotal" />
                                <TextBlock x:Name="SubtotalValue" FontWeight="SemiBold" Margin="6,0,0,0" Text="₹199"/>
                            </DockPanel>

                            <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,6">
                                <TextBlock Text="Taxes" />
                                <TextBlock x:Name="TaxValue" FontWeight="SemiBold" Margin="6,0,0,0" Text="₹18"/>
                            </DockPanel>

                            <Separator Grid.Row="2" Margin="0,4,0,6"/>

                            <DockPanel Grid.Row="3" LastChildFill="False">
                                <TextBlock Text="Total" FontSize="16" FontWeight="SemiBold"/>
                                <Border CornerRadius="6" Padding="10,4" Margin="8,0,0,0">
                                    <TextBlock x:Name="GrandTotalValue" FontSize="14" FontWeight="Bold" Text="₹217"/>
                                </Border>
                            </DockPanel>
                        </Grid>
                    </Border>

                    <!-- Payment badge -->
                        <Border BorderThickness="1" CornerRadius="8"
                            Padding="12" >
                        <StackPanel>
                            <TextBlock Text="Payment Status" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PaymentModeText" Margin="0,4,0,0" Text="UPI (paid)" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Footer buttons across bottom -->
                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                        <Button Content="Print…" Padding="12,6" Margin="0,0,8,0" BorderThickness="1"
                            Click="OnPrintClick"/>
                    <Button Content="Close" Padding="12,6" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
            </DockPanel>
        </ScrollViewer>
    </Border>


</Window>
