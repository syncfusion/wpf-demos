<democommon:DemoControl x:Class="syncfusion.notificationdemos.wpf.ToastCustomizationDemo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:syncfusion.notificationdemos.wpf"
             mc:Ignorable="d" xmlns:skinManager="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             d:DesignHeight="540" d:DesignWidth="860">

    <!-- ============================ -->
    <!--    TOAST TEMPLATES/STYLES    -->
    <!-- ============================ -->
    <democommon:DemoControl.Resources>
        <!-- Close: square chip (vector 'X' so it renders on all fonts) -->
        <DataTemplate x:Key="CloseButtonTemplate_Fluent">
            <Border CornerRadius="2"
                 BorderThickness="1">
                <Path Stretch="Uniform" Width="12" Height="12" StrokeThickness="2"
                  Data="M1,1 L9,9 M9,1 L1,9"/>
            </Border>
        </DataTemplate>

        <!-- Title area: compact clock badge + two-line title text (Order line + Delivery line) -->
        <DataTemplate x:Key="TitleTemplate_OrderConfirm">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Smaller clock badge (20x20) -->
                <Border Grid.Column="0" Background="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=ContentBackgroundAlt2}}"                                               
BorderBrush="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=BorderAlt}}"
                Width="20" Height="20" CornerRadius="5"
                BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Grid>
                            <Ellipse/>
                            <!-- clock hands -->
                            <Path Data="M10,5.5 L10,10 L13.5,10" StrokeLineJoin="Round"/>
                        </Grid>
                    </ScrollViewer>
                </Border>

                     <!-- Two-line title text comes entirely from Title (data item may be a string) -->
                     <TextBlock Grid.Column="2"
                         Text="{Binding ., Mode=OneWay, TargetNullValue='Order #12345', FallbackValue='Order #12345'}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         LineStackingStrategy="MaxHeight"
                         LineHeight="18"/>
            </Grid>
        </DataTemplate>
        <!-- Content: NO header/ETA here. Only details + thanks chip. -->
        <DataTemplate x:Key="ContentTemplate_OrderConfirm">
            <Border CornerRadius="12" BorderThickness="1" Padding="8" Background="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=ContentBackgroundAlt2}}"                                               
BorderBrush="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=BorderAlt}}">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Food icon -->
                    <Border Grid.RowSpan="2" Grid.Column="0"
                        CornerRadius="10" Width="64" Height="64"
                        Margin="0,4,0,0">
                        <TextBlock Text="🍽️" FontSize="28"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Details body -->
                    <Border Grid.Column="2" Grid.Row="0"
                        Margin="0,0,0,10" Padding="12"
                        CornerRadius="8" BorderThickness="1">
                           <TextBlock Text="{Binding ., Mode=OneWay, TargetNullValue='Order details not available', FallbackValue='Order details not available'}"
                               TextWrapping="Wrap" />
                    </Border>

                    <!-- Thanks chip -->
                    <Border Grid.Column="2" Grid.Row="1" CornerRadius="6"
                        Padding="10,8" >
                        <TextBlock Text="Thanks for ordering — we’ll keep you posted!"
                               FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

    </democommon:DemoControl.Resources>
    <!-- ============================ -->
    <!--         MAIN LAYOUT          -->
    <!-- ============================ -->
    <Grid Margin="16">
        <Border                                               
BorderBrush="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=BorderAlt1}}"
            BorderThickness="1" CornerRadius="14" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="5">
                <StackPanel Margin="0,0,8,0">

                    <TextBlock Text="Food Order — Demo Flow"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Pick your food, enter the address, and click Pay. We’ll show a rich toast with the order summary and delivery time." TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Conversation-like stack -->
                    <StackPanel>

                        <!-- Step 1 — Food -->
                        <Border  Background="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=ContentBackgroundAlt2}}"                                               
BorderBrush="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=BorderAlt}}"
                    BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="What would you like to order?" FontWeight="SemiBold" Margin="6"/>
                                <StackPanel Orientation="Horizontal" Margin="6">
                                    <StackPanel Width="220">
                                        <TextBlock Text="Food item" />
                                        <ComboBox x:Name="FoodCombo" SelectedIndex="0" Margin="0,6,0,0" Padding="6,2" Height="22.5" VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Cheeseburger — $8.99"/>
                                            <ComboBoxItem Content="BBQ Chicken Sandwich — $9.99"/>
                                            <ComboBoxItem Content="Veggie Wrap — $7.49"/>
                                            <ComboBoxItem Content="Buttermilk Pancakes — $5.99"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Width="90" Margin="12,0,0,0">
                                        <TextBlock Text="Qty" />
                                        <TextBox x:Name="QtyBox" Text="1" HorizontalContentAlignment="Center" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>
                                </StackPanel>

                                <WrapPanel Margin="6" ItemHeight="24">
                                    <CheckBox x:Name="AddonExtraCheese" Content="Extra cheese +$2.50" Margin="0,0,12,0"/>
                                    <CheckBox x:Name="AddonSpicy" Content="Spicy +$0.75" Margin="0,0,12,0"/>
                                    <CheckBox x:Name="AddonCutlery" Content="Eco cutlery +$0" Margin="0,0,0,0"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Step 2 — Address -->
                        <Border 
                    BorderThickness="1" CornerRadius="10" Padding="0,12,0,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Where should we deliver?" FontWeight="SemiBold"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Name" />
                                        <TextBox x:Name="NameBox" Text="Jane Doe" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="Phone" />
                                        <TextBox x:Name="PhoneBox" Text="555-123-4567" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                        <TextBlock Text="Address" />
                                        <TextBox x:Name="AddressBox" Text="123 Main St, Apt 4B" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,10,8,0">
                                        <TextBlock Text="City" />
                                        <TextBox x:Name="CityBox" Text="Springfield, IL" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock Text="ZIP" />
                                        <TextBox x:Name="PincodeBox" Text="62704" Margin="0,6,0,0" Padding="6,2"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Step 3 — Payment -->
                        <Border  Background="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=ContentBackgroundAlt2}}"                                               
BorderBrush="{skinManager:ThemeResource ThemeKey={skinManager:ThemeKey Key=BorderAlt}}"
                    BorderThickness="1" CornerRadius="10" Padding="0,12,0,12">
                            <StackPanel>
                                <TextBlock Text="Payment method" FontWeight="SemiBold" Margin="3"/>
                                <StackPanel Orientation="Horizontal" Margin="3">
                                    <RadioButton x:Name="PayUPI" Content="PayPal" IsChecked="True" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="PayCard" Content="Card" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="PayCOD" Content="Cash"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="3" VerticalAlignment="Center">
                                    <TextBlock Text="Subtotal:"/>
                                    <TextBlock x:Name="SubtotalText" FontWeight="SemiBold" Text="$0" Margin="4,0,0,0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="3">
                                    <Button x:Name="PayButton" Content="Pay And Place Order"
                                        Width="180" Height="34" Click="OnPayClick"/>
                                    <Button Content="Reset" Width="90" Height="34" Margin="8,0,0,0" Click="OnResetClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</democommon:DemoControl>
