<democommon:DemoControl
    x:Class="syncfusion.notificationdemos.wpf.GettingStartedSample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
    xmlns:local="clr-namespace:syncfusion.notificationdemos.wpf"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf" 
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800" OptionsSize="300">
    <democommon:DemoControl.Options>
        <Border Width="290">
            <TabControl Width="280">
                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4,4,12,4">
                        <StackPanel>
                            <!-- Title -->
                            <Label Content="Title" Margin="0,2"/>
                            <TextBox x:Name="TitleBox" Text="New Notification" Margin="0,0,0,4" Height="24" />

                            <!-- Header -->
                            <Label Content="Header" Margin="0,2"/>
                            <TextBox x:Name="HeaderBox" Margin="0,0,0,4" Text="Updates" Height="24" />

                            <!-- Message -->
                            <Label Content="Message" Margin="0,2"/>
                            <TextBox x:Name="MessageBox" Margin="0,0,0,4"
                               Text="Your project has been synchronized successfully." Height="24"/>

                            <!-- Duration -->
                            <Label Content="Duration (ms)" Margin="0,2"/>
                            <TextBox x:Name="DurationBox" Margin="0,0,0,4" Text="4000" Height="24"/>

                        <!-- Show Animation -->
                        <Label Content="Show Animation" Margin="0,2"/>
                        <ComboBox x:Name="ShowAnimCombo" Margin="0,0,0,4" Height="24">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="FadeIn" IsSelected="True"/>
                            <ComboBoxItem Content="SlideBottomIn"/>
                            <ComboBoxItem Content="FadeZoomIn"/>
                            <ComboBoxItem Content="FlipLeftDownIn"/>
                            <ComboBoxItem Content="FlipLeftUpIn"/>
                            <ComboBoxItem Content="FlipRightDownIn"/>
                        </ComboBox>

                            <!-- Close Animation -->
                            <Label Content="Close Animation" Margin="0,2"/>
                            <ComboBox x:Name="CloseAnimCombo" Margin="0,0,0,4" Height="24">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="FadeOut" IsSelected="True"/>
                                <ComboBoxItem Content="SlideBottomOut"/>
                                <ComboBoxItem Content="FadeZoomOut"/>
                                <ComboBoxItem Content="FlipLeftDownOut"/>
                                <ComboBoxItem Content="FlipLeftUpOut"/>
                                <ComboBoxItem Content="FlipRightDownOut"/>
                            </ComboBox>

                            <!-- Auto close -->
                            <CheckBox x:Name="PreventAutoCloseCheck"
                                Content="Prevent Auto Close"
                                Margin="0,8,0,4"/>

                            <!-- Buttons visibility -->
                            <CheckBox x:Name="ShowCloseCheck"
                                Content="Show Close Button"
                                Margin="0,8,0,4" IsChecked="True"/>

                            <CheckBox x:Name="ShowActionsCheck"
                                Content="Show Action Buttons"
                                Margin="0,8,0,4" IsChecked="True"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Appearance">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4,4,12,4">
                        <StackPanel>

                            <!-- Mode -->
                            <Label Content="Display Mode" Margin="0,2"/>
                            <ComboBox x:Name="ModeCombo" Margin="0,0,0,4" Height="24">
                                <ComboBoxItem Content="InWindow"/>
                                <ComboBoxItem Content="Screen" IsSelected="True"/>
                            </ComboBox>

                        <!-- Severity -->
                        <Label Content="Severity" Margin="0,2"/>
                            <syncfusion:ComboBoxAdv x:Name="SeverityCombo" SelectedIndex="0" Margin="0,0,0,4" Height="24" SelectionChanged="SeverityCombo_SelectionChanged">
                                <syncfusion:ComboBoxItemAdv Content="None"/>
                                <syncfusion:ComboBoxItemAdv Content="Info"/>
                                <syncfusion:ComboBoxItemAdv Content="Success"/>
                                <syncfusion:ComboBoxItemAdv Content="Warning"/>
                                <syncfusion:ComboBoxItemAdv Content="Error"/>
                            </syncfusion:ComboBoxAdv>

                            <!-- Variant -->
                            <Label Content="Variant" Margin="0,2"/>
                            <syncfusion:ComboBoxAdv x:Name="VariantCombo" Margin="0,0,0,4" Height="24" DefaultText="Select Varient...">
                                <syncfusion:ComboBoxItemAdv Content="Text"/>
                                <syncfusion:ComboBoxItemAdv Content="Outlined"/>
                                <syncfusion:ComboBoxItemAdv Content="Filled"/>
                            </syncfusion:ComboBoxAdv>

                            <!-- Placement -->
                            <Label Content="Placement" Margin="0,2"/>
                            <ComboBox x:Name="PlacementCombo" Margin="0,0,0,4" Height="24">
                                <ComboBoxItem Content="TopLeft"/>
                                <ComboBoxItem Content="TopCenter"/>
                                <ComboBoxItem Content="TopRight"/>
                                <ComboBoxItem Content="LeftCenter"/>
                                <ComboBoxItem Content="RightCenter"/>
                                <ComboBoxItem Content="BottomLeft"/>
                                <ComboBoxItem Content="BottomCenter"/>
                                <ComboBoxItem Content="BottomRight" IsSelected="True"/>
                            </ComboBox>

                        <!-- Style -->
                        <Label Content="Accent Brush" Margin="0,2"/>
                            <syncfusion:ColorPicker x:Name="ForegroundBox" Margin="0,0,0,4" IsEnabled="False"/>
                        </StackPanel>
                </ScrollViewer>
            </TabItem>

            </TabControl>
        </Border>
    </democommon:DemoControl.Options>
    <Grid>
        <Border
                BorderThickness="1"
                Padding="20"
                CornerRadius="8">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Button Content="Show Toast"
                    Width="140"
                    Height="34"
                    HorizontalAlignment="Center"
                    Click="OnShowToastClick"/>

                <Button Content="Close All"
                    Width="140"
                    Height="34"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center"
                    Click="OnCloseAllClick"/>
            </StackPanel>

        </Border>

    </Grid>

</democommon:DemoControl>
