<democommon:DemoControl x:Class="syncfusion.smarttexteditordemos.wpf.SmartTextEditorDemo"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
                        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                        xmlns:local="clr-namespace:syncfusion.smarttexteditordemos.wpf.Properties"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                        xmlns:sync="clr-namespace:Syncfusion.UI.Xaml.SmartComponents;assembly=Syncfusion.SfSmartComponents.Wpf"
                        xmlns:viewmodel="clr-namespace:syncfusion.smarttexteditordemos.wpf.ViewModel"
                        xmlns:sfskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
                        OptionsSize="Auto"
                        mc:Ignorable="d">
    <democommon:DemoControl.DataContext>
        <viewmodel:SmartTextEditorViewModel />
    </democommon:DemoControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Image Source="/syncfusion.smarttexteditordemos.wpf;component/Assets/gettingstarted.png"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
        <Grid Grid.Column="1"
              Background="{sfskin:ThemeResource ThemeKey={sfskin:ThemeKey Key=ContentBackgroundAlt1}}">
            <Border Margin="20"
                    CornerRadius="20"
                    BorderThickness="0"
                    BorderBrush="{sfskin:ThemeResource ThemeKey={sfskin:ThemeKey Key=BorderAlt}}"
                    VerticalAlignment="Center"
                    Background="{sfskin:ThemeResource ThemeKey={sfskin:ThemeKey Key=ContentBackground}}">
                <Border.Effect>
                    <DropShadowEffect Color="#1C244B"
                                      BlurRadius="18"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.15"
                                      RenderingBias="Quality" />
                </Border.Effect>
                <StackPanel Margin="20">
                    <TextBlock Text="Role"
                               FontWeight="Bold" />
                    <syncfusion:ComboBoxAdv x:Name="UserRoleSelection"
                                            SelectedIndex="0"
                                            ItemsSource="{Binding Roles}"
                                            SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                            DisplayMemberPath="Text"
                                            Height="30"
                                            Margin="0,10,0,10" />

                    <TextBlock Text="Response"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />
                    <sync:SfSmartTextEditor x:Name="SmartTextArea"
                                            Placeholder="Write your response...."
                                            UserRole="{Binding SelectedRole.Text}"
                                            UserPhrases="{Binding SelectedRole.SuggestionPhrases}"
                                            Height="150" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</democommon:DemoControl>

