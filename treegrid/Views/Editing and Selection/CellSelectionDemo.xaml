<democommon:DemoControl
    x:Class="syncfusion.treegriddemos.wpf.CellSelectionDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
    xmlns:local="clr-namespace:syncfusion.treegriddemos.wpf"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf" >

    <democommon:DemoControl.DataContext>
        <local:EmployeeInfoViewModel />
    </democommon:DemoControl.DataContext>

    <democommon:DemoControl.Resources>
        <democommon:EnumDisplayNameConverter x:Key="enumDisplayNameConverter" />
    </democommon:DemoControl.Resources>

    <democommon:DemoControl.Options>
        <StackPanel>
            <TextBlock
                x:Name="textBlock1"
                Margin="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold"
                Text="Selection Mode:" />
            <ComboBox
                x:Name="cmbSelectionMode"
                Height="25"
                Margin="5"
                ItemsSource="{democommon:EnumValuesExtension Type=syncfusion:GridSelectionMode}"
                SelectedIndex="1">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock VerticalAlignment="Center" Text="{Binding Converter={StaticResource enumDisplayNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock
                x:Name="textBlock3"
                Margin="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold"
                Text="Selection Brush:" />

            <syncfusion:ColorPicker
                x:Name="colorPicker"
                Margin="5"
                Brush="{Binding Path=SelectionBackground, ElementName=treeGrid, Mode=TwoWay}" />
        </StackPanel>
    </democommon:DemoControl.Options>

    <Grid>
        <syncfusion:SfTreeGrid
            Name="treeGrid"
            AutoExpandMode="RootNodesExpanded"
            AutoGenerateColumns="False"
            ChildPropertyName="ReportsTo"
            ColumnSizer="Star"
            ItemsSource="{Binding EmployeesListInfo}"
            LiveNodeUpdateMode="AllowDataShaping"
            ParentPropertyName="ID"
            SelectedIndex="0"
            SelectionMode="{Binding SelectedValue, ElementName=cmbSelectionMode}"
            SelectionUnit="Cell"
            SelectionBackground="{Binding Path=Brush, ElementName=colorPicker, Mode=TwoWay}">

            <interactivity:Interaction.Behaviors>
                <local:SfTreeGridSelectionBehavior />
            </interactivity:Interaction.Behaviors>

            <syncfusion:SfTreeGrid.Columns>
                <syncfusion:TreeGridTextColumn MappingName="Title" />
                <syncfusion:TreeGridNumericColumn
                    HeaderText="Employee ID"
                    MappingName="ID"
                    NumberDecimalDigits="0" />
                <syncfusion:TreeGridTextColumn HeaderText="First Name" MappingName="FirstName" />
                <syncfusion:TreeGridTextColumn HeaderText="Last Name" MappingName="LastName" />
                <syncfusion:TreeGridCurrencyColumn
                    CurrencyDecimalDigits="2"
                    CurrencySymbol="$"
                    HeaderText="Salary"
                    MappingName="Salary" />
            </syncfusion:SfTreeGrid.Columns>
        </syncfusion:SfTreeGrid>
    </Grid>
</democommon:DemoControl>