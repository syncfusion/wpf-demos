<democommon:DemoControl
    x:Class="syncfusion.treegriddemos.wpf.SerializationDemo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:democommon="clr-namespace:syncfusion.demoscommon.wpf;assembly=syncfusion.demoscommon.wpf"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:syncfusion.treegriddemos.wpf"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
    xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
    syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=Windows11Light}"
    OptionsSize="300"
    Background="#FFFFFF">

    <democommon:DemoControl.DataContext>
        <local:EmployeeInfoViewModel />
    </democommon:DemoControl.DataContext>

    <democommon:DemoControl.Options>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border>
                <ItemsControl IsTabStop="False">
                    <StackPanel>
                        <Expander Margin="5" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock
                                    x:Name="textBlock1"
                                    Margin="4"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Serialization Options" />
                            </Expander.Header>
                            <StackPanel Margin="5">

                                <CheckBox
                                    x:Name="SerializeColumns"
                                    Margin="6"
                                    Content="Serialize Columns"
                                    IsChecked="{Binding Source={x:Reference SerializationOptions}, Path=SerializeColumns}"/>
                                <CheckBox
                                    x:Name="SerializeStackedHeaders"
                                    Margin="6"
                                    Content="Serialize StackedHeaders"
                                    IsChecked="{Binding Source={x:Reference SerializationOptions}, Path=SerializeStackedHeaders}"/>
                                <CheckBox
                                    x:Name="SerializeSorting"
                                    Margin="6"
                                    Content="Serialize Sorting"
                                    IsChecked="{Binding Source={x:Reference SerializationOptions}, Path=SerializeSorting}"/>
                                <CheckBox
                                    x:Name="SerializeFiltering"
                                    Margin="6"
                                    Content="Serialize Filtering"
                                    IsChecked="{Binding Source={x:Reference SerializationOptions}, Path=SerializeFiltering}"/>

                                <Button
                                    x:Name="button1"
                                    Width="150"
                                    Height="25"
                                    Margin="6"
                                    HorizontalAlignment="Left"
                                    Command="local:SerializationCommands.Serialize"
                                    CommandTarget="{Binding Source={x:Reference treeGrid}}"
                                    Content="Serialize">
                                    <Button.CommandParameter>
                                        <syncfusion:TreeGridSerializationOptions x:Name="SerializationOptions" />
                                    </Button.CommandParameter>
                                </Button>
                            </StackPanel>
                        </Expander>
                        <Expander Margin="5">
                            <Expander.Header>
                                <TextBlock
                                    x:Name="textBlock2"
                                    Margin="4"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Deserialization Options" />
                            </Expander.Header>
                            <StackPanel Margin="5">

                                <CheckBox
                                    x:Name="DeserializeColumns"
                                    Margin="6"
                                    Content="Deserialize Columns"
                                    IsChecked="{Binding Source={x:Reference DeserializationOptions}, Path=DeserializeColumns}" />
                                <CheckBox
                                    x:Name="DeserializeStackedHeaders"
                                    Margin="6"
                                    Content="Deserialize StackedHeaders"
                                    IsChecked="{Binding Source={x:Reference DeserializationOptions}, Path=DeserializeStackedHeaders}" />
                                <CheckBox
                                    x:Name="DeserializeSorting"
                                    Margin="6"
                                    Content="Deserialize Sorting"
                                    IsChecked="{Binding Source={x:Reference DeserializationOptions}, Path=DeserializeSorting}" />
                                <CheckBox
                                    x:Name="DeserializeFiltering"
                                    Margin="6"
                                    Content="Deserialize Filtering"
                                    IsChecked="{Binding Source={x:Reference DeserializationOptions}, Path=DeserializeFiltering}" />

                                <Button
                                    x:Name="button3"
                                    Width="150"
                                    Height="25"
                                    Margin="6"
                                    HorizontalAlignment="Left"
                                    Command="local:SerializationCommands.Deserialize"
                                    CommandTarget="{Binding Source={x:Reference treeGrid}}"
                                    Content="Deserialize">
                                    <Button.CommandParameter>
                                        <syncfusion:TreeGridDeserializationOptions x:Name="DeserializationOptions" />
                                    </Button.CommandParameter>
                                </Button>
                                <Button
                                    x:Name="button2"
                                    Width="150"
                                    Height="25"
                                    Margin="6"
                                    HorizontalAlignment="Left"
                                    Command="local:SerializationCommands.Reset"
                                    CommandTarget="{Binding Source={x:Reference treeGrid}}"
                                    Content="Reset" />
                            </StackPanel>
                        </Expander>
                        <Expander Margin="5">
                            <Expander.Header>
                                <TextBlock
                                    x:Name="textBlock3"
                                    Margin="3"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Text="Add/Remove column Options" />
                            </Expander.Header>
                            <StackPanel Margin="5">

                                <Button
                                    x:Name="button4"
                                    Width="150"
                                    Height="25"
                                    Margin="6"
                                    HorizontalAlignment="Left"
                                    Command="local:SerializationCommands.Add"
                                    CommandTarget="{Binding Source={x:Reference treeGrid}}"
                                    Content="Add Column" />

                                <Button
                                    x:Name="button5"
                                    Width="150"
                                    Height="25"
                                    Margin="6"
                                    HorizontalAlignment="Left"
                                    Command="local:SerializationCommands.Remove"
                                    CommandTarget="{Binding Source={x:Reference treeGrid}}"
                                    Content="Remove Column" />

                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ItemsControl>
            </Border>
        </ScrollViewer>
    </democommon:DemoControl.Options>

    <Grid>
        <syncfusion:SfTreeGrid
            Name="treeGrid"
            Margin="5"
            AutoGenerateColumns="False"
            ColumnSizer="Star"
            AllowFiltering="True"
            FilterLevel="All"
            ItemsSource="{Binding EmployeeList}"
            AutoExpandMode="RootNodesExpanded"
            ChildPropertyName="ReportsTo"
            ParentPropertyName="ID"
            SelfRelationRootValue="-1"
            ExpanderColumn="FirstName">
            <interactivity:Interaction.Behaviors>
                <local:TreeGridSerializationBehavior/>
            </interactivity:Interaction.Behaviors>

            <syncfusion:SfTreeGrid.Columns>
                <syncfusion:TreeGridTextColumn HeaderText="First Name" MappingName="FirstName" />
                <syncfusion:TreeGridNumericColumn HeaderText="Employee ID" MappingName="ID" NumberDecimalDigits="0" />
                <syncfusion:TreeGridTextColumn HeaderText="Last Name" MappingName="LastName" />
                <syncfusion:TreeGridCurrencyColumn HeaderText="Salary" MappingName="Salary" />
                <syncfusion:TreeGridNumericColumn HeaderText="Reports To" MappingName="ReportsTo" NumberDecimalDigits="0" />
            </syncfusion:SfTreeGrid.Columns>

            <syncfusion:SfTreeGrid.StackedHeaderRows>
                <syncfusion:StackedHeaderRow>
                    <syncfusion:StackedHeaderRow.StackedColumns>
                        <syncfusion:StackedColumn ChildColumns="FirstName,ID,LastName,Salary,ReportsTo" HeaderText="Employee Details" />
                    </syncfusion:StackedHeaderRow.StackedColumns>
                </syncfusion:StackedHeaderRow>
            </syncfusion:SfTreeGrid.StackedHeaderRows>
        </syncfusion:SfTreeGrid>
    </Grid>
</democommon:DemoControl>
