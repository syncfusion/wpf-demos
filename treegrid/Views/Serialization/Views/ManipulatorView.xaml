<Window
    x:Class="syncfusion.treegriddemos.wpf.ManipulatorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:syncfusion.treegriddemos.wpf"
    xmlns:skin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
    x:Name="ManipulatorWnd"
    Title="Column Manipulation"
    Width="300"
    Height="228"
    AllowsTransparency="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    Background="#FFFFFF">
    <Grid skin:SfSkinManager.Theme="{skin:SkinManagerExtension ThemeName=Windows11Light}">
        <Border Margin="5" Background="White">
            <Border.Effect>
                <DropShadowEffect
                Direction="200"
                Opacity="0.35"
                ShadowDepth="0" />
            </Border.Effect>

            <StackPanel Margin="5">
                <StackPanel x:Name="addcolarea" Margin="5">
                    <TextBlock
                    Margin="4"
                    FontSize="12"
                    FontWeight="Bold"
                    Text="Add Column" />
                    <TextBlock
                    Margin="4"
                    FontSize="12"
                    Text="Select Column Type" />

                    <ComboBox x:Name="colType_combobox" Margin="0,2,0,4">
                        <ComboBoxItem>TreeGridTextColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridNumericColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridDateTimeColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridCurrencyColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridCheckBoxColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridTemplateColumn</ComboBoxItem>
                        <ComboBoxItem>TreeGridPercentColumn</ComboBoxItem>
                        <interactivity:Interaction.Behaviors>
                            <local:ComboBoxColumnBehavior />
                        </interactivity:Interaction.Behaviors>
                    </ComboBox>
                </StackPanel>
                <TextBlock
                x:Name="removecol_Tilte"
                Margin="4"
                FontSize="12"
                FontWeight="Bold"
                Text="Remove Column" />
                <StackPanel x:Name="normalcol_Stackpanel">
                    <Label x:Name="Mappingname_Label" Content="MappingName" />
                    <ComboBox x:Name="mappingname_cmbbox" Margin="4,2,4,4">
                        <interactivity:Interaction.Triggers>
                            <interactivity:EventTrigger EventName="DropDownOpened">
                                <local:MappingNameComboBoxTrigger />
                            </interactivity:EventTrigger>
                        </interactivity:Interaction.Triggers>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button
                    x:Name="addnormalCol"
                    Grid.Row="9"
                    Width="120"
                    Height="30"
                    Margin="4,12,10,10"
                    Command="local:ManipulatorViewCommands.AddColumn"
                    CommandTarget="{Binding ElementName=ManipulatorWnd}"
                    Content="Add" />
                    <Button
                    x:Name="removenormalCol"
                    Width="120"
                    Height="30"
                    Margin="4,12,10,10"
                    Command="local:ManipulatorViewCommands.RemoveColumn"
                    CommandTarget="{Binding ElementName=ManipulatorWnd}"
                    Content="Remove"
                    RenderTransformOrigin="-0.175,0.533" />

                    <Button
                    Width="120"
                    Height="30"
                    Margin="22,4,4,4"
                    Content="Cancel"
                    IsCancel="True" />

                </StackPanel>
                <TextBlock
                x:Name="err_textblock"
                Margin="4,0,0,0"
                Foreground="Red"
                Visibility="Hidden" />

            </StackPanel>

        </Border>
    </Grid>
</Window>
